{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Startup Tray Manager",
  "version": "1.0.0",
  "identifier": "com.zyz.startuptraymanager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Startup Tray Manager",
        "width": 460,
        "height": 560,
        "minWidth": 400,
        "minHeight": 520,
        "visible": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
